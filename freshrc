ln -sf ~/.dotfiles/.screenlayout ~/.screenlayout

ln -sf ~/.dotfiles/config/i3 ~/.config/i3
ln -sf ~/.dotfiles/config/rofi ~/.config/rofi
ln -sf ~/.dotfiles/config/polybar ~/.config/polybar
ln -sf ~/.dotfiles/config/neofetch ~/.config/neofetch
ln -sf ~/.dotfiles/config/kitty ~/.config/kitty
ln -sf ~/.dotfiles/config/autorandr ~/.config/autorandr
ln -sf ~/.dotfiles/config/qutebrowser ~/.config/qutebrowser
ln -sf ~/.dotfiles/config/mpv ~/.config/mpv

ln -sf ~/.dotfiles/compton.conf ~/.config/compton.conf
ln -sf ~/.dotfiles/vim/coc-settings.json ~/.config/nvim/coc-settings.json
ln -sf ~/.dotfiles/mimeapps.list ~/.config/mimeapps.list
