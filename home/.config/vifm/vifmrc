" vim: filetype=vifm
source ~/.config/vifm/vifmshortcuts

set vicmd=$EDITOR
set syscalls " use vifm for file operations for progress etc
set nofollowlinks " auto resolve symlinks on l or Enter
set sortnumbers " natural sort of numbers within text
set undolevels=100
set wildmenu
set wildstyle=popup
set scrolloff=4
set ignorecase
set smartcase
set nohlsearch
set incsearch
set suggestoptions=normal,visual,view,otherpane,keys,marks,registers
set confirm=permdelete
set dotdirs=rootparent

colorscheme gruvbox

" window management
map <C-h> <C-w>h
map <C-j> <C-w>j
map <C-k> <C-w>k
map <C-l> <C-w>l
map <C-o> <C-w>o
map <C-s> <C-w>s
map <C-v> <C-w>v

" rename
nnoremap I cw<c-a>
nnoremap cc cw<c-u>
nnoremap A cw

" yanking
" make a backup copy in the same pane
nmap yp :clone <cr>
" path to directory
nnoremap yd :!echo %d | wl-copy %i<cr>
" path to file
nnoremap yf :!echo %c:p | wl-copy %i<cr>
" copy to opposite pane
" nmap yy :!copy %f %D<cr>
" move to opposite pane
" nmap yY :!move %f %D<cr>

" other
map R :restart<CR>
nnoremap o :file &<cr>
map mkd :mkdir<space>
nmap <space> tj

" file actions
nnoremap w :view<cr>
vnoremap w :view<cr>gv
map E :!$EDITOR %f<CR>
map X :!ext %f &<CR>

" other commands (to review)
nnoremap zo :sync %c<CR><Tab>
" map x :!sxiv -ft * 2>/dev/null &<CR>
" map bg :!setbg %f &<CR>
" nnoremap s :shell<cr>
" nnoremap ,w :set wrap!<cr>

fileview */ tree %c -L 1 --dirsfirst
fileview ../ tree %c -L 1 --dirsfirst
fileviewer *.html w3m -dump %c
filextype *.html,*.htm firefox %f 2>/dev/null &

fileviewer *.docx docx2txt %c -
fileviewer *.odt odt2txt %c -

filetype *.csv,*.xlsx sc-im %c
fileviewer *.csv sed "s/,,,,/,,-,,/g;s/,,/ /g" %c | column -t | sed "s/ - /  /g" | cut -c -%pw

filetype *.wav,*.mp3,*.flac,*.m4a,*.wma,*.ape,*.ac3,*.og[agx],*.spx,*.opus mpv --no-audio-display --input-ipc-server=/tmp/mpvsoc$(date +%%s) %c
filextype *.pdf,*.ps,*.eps,*.ps.gz,*.djvu,*.epub zathura %f 2>/dev/null &,
fileviewer *.pdf pdftotext -l 1 -nopgbrk %c -
fileviewer *.avi,*.mp4,*.wmv,*.dat,*.3gp,*.ogv,*.mkv,*.mpg,*.mpeg,*.vob,*.fl[icv],*.m2v,*.mov,*.webm,*.ts,*.mts,*.m4v,*.qt,*.divx,*.as[fx],*mp3,*.flac file
filextype *.avi,*.mp4,*.wmv,*.dat,*.3gp,*.ogv,*.mkv,*.mpg,*.mpeg,*.vob,*.fl[icv],*.m2v,*.mov,*.webm,*.ts,*.mts,*.m4v,*.r[am],*.qt,*.divx,*.as[fx] umpv --input-ipc-server=/tmp/mpvsoc$(date +%%s) %f 2>/dev/null &,

fileview *.zip,*.rar,*.tar.gz atool -l %f
filetype *.zip,*.rar,*.tar.gz ext %f

fileviewer *.[1-8] man ./%c | col -b
filetype *.[1-8] man ./%c

fileviewer *.jpg,*.jpeg,*.png,*.ico
  \ kitty-img-preview %pw %ph %px %py %c 2>/dev/null
  \ %pc
  \ kitty-img-preview clear 2>/dev/null

filextype *.bmp,*.jpg,*.jpeg,*.png,*.ico,*.gif,*.xpm,*.svg  rotdir %f 2>/dev/null | imv 2>/dev/null &

set vifminfo=dhistory,chistory,tui,shistory,phistory,fhistory,dirstack,registers,bookmarks,bmarks

