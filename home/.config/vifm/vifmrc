" nmap DD :!trash-empty <cr>

" :com[mand][!] command_name action
" The following macros can be used in a command
" %a is replaced with the user arguments.
" %c the current file under the cursor.
" %C the current file under the cursor in the other directory.
" %f the current selected file, or files.
" %F the current selected file, or files in the other directory.
" %b same as %f %F.
" %d the current directory name.
" %D the other window directory name.
" %m run the command in a menu window


command! fzf :execute 'goto "'.system('fd --type file --hidden --exclude .git --color always --follow | fzf --height 10 2>/dev/tty ').'"%IU' | redraw

command! fzfD :execute 'cd "'.system('fd --type d . $HOME | fzf --height 10 2>/dev/tty ').'"%IU' | redraw
nnoremap <c-f> :fzfD<cr>
nnoremap <c-p> :fzf<cr>

" Fast way to add bmark without having to type the folder name (shortcut)
command! fmark :execute 'bmark "' .system('echo "${PWD##*/}"').'"'
nnoremap M :fbmark<cr>

command! fzfbookmarks :execute "normal! :bmarks\r:write ~/.vifm/fzf-read/bookmarks\rq"
                   \ | execute 'cd "'.system('cat ~/.vifm/fzf-read/bookmarks | sed "s/:.*//" |  fzf 2>/dev/tty').'"'
nnoremap <c-g> :fzfbookmarks<cr>
